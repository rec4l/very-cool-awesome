{
  "name": "very-cool-awesome",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite client",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "vite build client && esbuild server/src/index.ts --bundle --platform=node --packages=external --outfile=server/dist/index.js --alias:@shared=./shared",
    "start": "node server/dist/index.js",
    "resize": "node scripts/resize-png.cjs",
    "gen:hud": "node scripts/gen-hud-placeholders.cjs",
    "gen:arena": "node scripts/gen-arena-bg.cjs",
    "gen:countdown": "node scripts/gen-countdown-placeholders.cjs",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "howler": "^2.2.4",
    "matter-js": "^0.19.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/howler": "^2.2.13",
    "@types/matter-js": "^0.19.3",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.50.0",
    "pixi.js": "^7.3.2",
    "prettier": "^3.0.0",
    "socket.io-client": "^4.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.2.0",
    "vite": "^4.5.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "debug": "~4.3.0"
  }
}
